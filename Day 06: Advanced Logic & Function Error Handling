def addition():
	num1 = int(input("Enter the first number: "))
	num2 = int(input("Enter the second number: "))
	print(f"{num1 + num2}")
	
def subtraction():
	num1 = int(input("Enter the first number: "))
	num2 = int(input("Enter the second number: "))
	print(f"{num1 - num2}")
	
def multiplication():
	num1 = int(input("Enter the first number: "))
	num2 = int(input("Enter the second number: "))
	print(f"{num1 * num2}")

def division():
	num1 = int(input("Enter the first number: "))
	num2 = int(input("Enter the second number: "))
	if num2 == 0:
		print("It cannot be divided by zero")
		
	else:
		print(f"{num1 / num2}")
		
	
operations = input("Choose the calculation operation: ")

if operations == "+":
	addition()
	
elif operations == "-":
	subtraction()
	
elif operations in ["*", "×"]
	multiplication()
	
elif operations in ["/", "÷"]:
	division()
	
	
else:
	print("This is not a calculation please try again")
